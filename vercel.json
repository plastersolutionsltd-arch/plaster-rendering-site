{
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    { "source": "/plastering-sheffield/",      "destination": "/plastering-sheffield",        "permanent": true },
    { "source": "/plastering/",               "destination": "/plastering-sheffield",        "permanent": true },
    { "source": "/plastering",                "destination": "/plastering-sheffield",        "permanent": true },
    { "source": "/silicone-render/",          "destination": "/silicone-render-sheffield",   "permanent": true },
    { "source": "/silicone-render",           "destination": "/silicone-render-sheffield",   "permanent": true },
    { "source": "/monocouche-render/",        "destination": "/monocouche-render-sheffield", "permanent": true },
    { "source": "/monocouche-render",         "destination": "/monocouche-render-sheffield", "permanent": true },
    { "source": "/ewi-sheffield/",            "destination": "/ewi-sheffield",               "permanent": true },
    { "source": "/ewi/",                      "destination": "/ewi-sheffield",               "permanent": true },
    { "source": "/ewi",                       "destination": "/ewi-sheffield",               "permanent": true },
    { "source": "/external-wall-insulation/", "destination": "/ewi-sheffield",               "permanent": true },
    { "source": "/external-wall-insulation",  "destination": "/ewi-sheffield",               "permanent": true },
    { "source": "/internal-plastering/",      "destination": "/plastering-sheffield",        "permanent": true },
    { "source": "/internal-plastering",       "destination": "/plastering-sheffield",        "permanent": true },
    { "source": "/dry-lining/",              "destination": "/dry-lining-sheffield",        "permanent": true },
    { "source": "/dry-lining",               "destination": "/dry-lining-sheffield",        "permanent": true },
    { "source": "/pricing/",                 "destination": "/pricing",                     "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/silicone-render-sheffield",   "destination": "/silicone-render-sheffield.html" },
    { "source": "/monocouche-render-sheffield", "destination": "/monocouche-render-sheffield.html" },
    { "source": "/ewi-sheffield",               "destination": "/ewi-sheffield.html" },
    { "source": "/plastering-sheffield",        "destination": "/plastering-sheffield.html" },
    { "source": "/dry-lining-sheffield",        "destination": "/dry-lining-sheffield.html" },
    { "source": "/pricing",                     "destination": "/pricing.html" },
    { "source": "/get-quote",                   "destination": "/get-quote.html" },
    { "source": "/get-quote/",                  "destination": "/get-quote.html" },
    { "source": "/services/", "destination": "/index.html" },
    { "source": "/portfolio/", "destination": "/index.html" },
    { "source": "/how-we-apply",  "destination": "/how-we-apply.html" },
    { "source": "/how-we-apply/", "destination": "/how-we-apply.html" },
    { "source": "/warranties/", "destination": "/index.html" },
    { "source": "/faq/", "destination": "/faq.html" },
    { "source": "/faq",  "destination": "/faq.html" },
    { "source": "/contact/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/app.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/react.production.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/react-dom.production.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/app.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
